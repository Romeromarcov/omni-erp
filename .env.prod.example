# .env.prod.example — Variables de entorno para PRODUCCIÓN
# ─────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. cp .env.prod.example .env.prod
#   2. Completar TODOS los valores marcados con <CAMBIAR>
#   3. Nunca commitear .env.prod al repositorio
#   4. Rotar SECRET_KEY antes del primer deploy
# ─────────────────────────────────────────────────────────────

# ── Django ──────────────────────────────────────────────────
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<CAMBIAR_clave_secreta_minimo_50_caracteres>

# Hosts separados por coma (sin http://, sin trailing slash)
DJANGO_ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# Orígenes CORS permitidos (con protocolo)
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=omni_erp
DB_USER=omni_erp
DB_PASSWORD=<CAMBIAR_password_postgres_robusto>

# ── Redis ────────────────────────────────────────────────────
# En docker-compose.prod.yml Redis no tiene password por defecto.
# Para habilitar auth: agregar requirepass en el comando de redis
# y actualizar esta URL.
REDIS_URL=redis://redis:6379/0

# ── S3 / MinIO ───────────────────────────────────────────────
USE_S3=True
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=<CAMBIAR_minio_access_key>
S3_SECRET_KEY=<CAMBIAR_minio_secret_key_minimo_8_chars>
S3_BUCKET_NAME=omni-erp
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRES=3600

# ── Redpanda / Kafka ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# ── Email (notificaciones Celery) ────────────────────────────
# Usar SMTP real en producción (no console backend)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.tuproveedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=<CAMBIAR_usuario_smtp>
EMAIL_HOST_PASSWORD=<CAMBIAR_password_smtp>
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# ── Sentry (observabilidad) ──────────────────────────────────
# Obtener DSN en https://sentry.io — dejar vacío para deshabilitar
SENTRY_DSN=

# ── SaaS ─────────────────────────────────────────────────────
# Activar verificación de suscripciones cuando esté listo
SAAS_VERIFICAR_SUSCRIPCION=False
