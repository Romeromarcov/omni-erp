# ─────────────────────────────────────────────────────────────────
# Omni ERP — Variables de entorno de ejemplo
# Copiá este archivo como .env y completá los valores reales.
# El archivo .env está en .gitignore — NUNCA lo commitas.
# ─────────────────────────────────────────────────────────────────

# Entorno: 'dev' o 'prod'
DJANGO_ENV=dev

# Clave secreta de Django
# Generá una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-real

# Hosts permitidos (separados por coma)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos PostgreSQL (OBLIGATORIO — SQLite no está soportado) ───
# Para desarrollo local, instalá PostgreSQL y creá la DB con:
#   createuser -h localhost -p 5432 --pwprompt omni_erp
#   createdb -h localhost -p 5432 -O omni_erp omni_erp
#
# Ver README.md sección "Desarrollo local" para instrucciones completas.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=omni_erp
DB_USER=omni_erp
DB_PASSWORD=cambia-esto-por-password-segura

# ─── Redis (Celery + cache de Django, P2-4) ───
# Opcional en dev: sin REDIS_URL el cache de Django cae a LocMem (por proceso)
# y Celery usa su default local. Con REDIS_URL (Railway la inyecta), Celery usa
# la URL tal cual (DB 0) y el cache de Django usa REDIS_CACHE_DB (default 1) —
# SIEMPRE una DB distinta a la del broker (cache.clear() hace FLUSHDB).
# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_DB=1
# Prefijo de claves del cache por entorno (default: omni:<RAILWAY_ENVIRONMENT|dev>)
# CACHE_KEY_PREFIX=omni:dev

# ─── CORS (solo requerido en producción) ───
CORS_ALLOWED_ORIGINS=https://app.tudominio.com

# ─── SaaS — control de acceso por pago (Plan C / C2) ───
# Si es True, un tenant sin suscripción vigente recibe HTTP 402 en toda la API
# (salvo rutas excluidas: /api/auth/, /api/saas/, /admin/, etc.). Off por
# defecto (fail-open). Actívalo PRIMERO en staging para validar el flujo 402.
SAAS_VERIFICAR_SUSCRIPCION=False
