# Ejemplo de variables de entorno para Omni ERP
# Copiar a .env y completar los valores reales
DEBUG=1
SECRET_KEY=your-secret-key-min-50-chars-change-in-production

# PostgreSQL — desarrollo local (PG18 nativo puerto 5433)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=omni_erp
DB_USER=omni_erp
DB_PASSWORD=omni_erp

# Redis — broker de Celery y caché
# Dev local (Redis nativo):
REDIS_URL=redis://localhost:6379/0
# Dev Docker (usar nombre del servicio):
# REDIS_URL=redis://redis:6379/0

# S3 / MinIO — almacenamiento de archivos
# USE_S3=False → usa filesystem local (dev sin MinIO)
# USE_S3=True  → usa S3-compatible (MinIO o AWS S3)
USE_S3=False
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=omni-erp
S3_REGION=us-east-1
# Segundos de validez de URLs pre-firmadas (default 1 hora)
S3_PRESIGNED_URL_EXPIRES=3600
