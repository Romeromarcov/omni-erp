# Ejemplo de variables de entorno para Omni ERP
# Copiar a .env y completar los valores reales
DEBUG=1
SECRET_KEY=your-secret-key-min-50-chars-change-in-production

# PostgreSQL — desarrollo local (PG18 nativo puerto 5433)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=omni_erp
DB_USER=omni_erp
DB_PASSWORD=omni_erp

# Redis — broker de Celery y caché
# Dev local (Redis nativo):
REDIS_URL=redis://localhost:6379/0
# Dev Docker (usar nombre del servicio):
# REDIS_URL=redis://redis:6379/0
