# Normalize line endings
* text=auto

# Python files — always LF
*.py text eol=lf
*.sh text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Web files — always LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.exe binary
*.dll binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
