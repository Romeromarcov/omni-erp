{
  "appId": "com.omnierp.app",
  "productName": "Omni ERP",
  "copyright": "Omni ERP",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": ["electron/**/*", "dist/**/*", "package.json"],
  "extraMetadata": {
    "main": "electron/main.cjs"
  },
  "win": {
    "target": ["nsis", "portable"],
    "icon": "public/pwa-512x512.png"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "artifactName": "OmniERP-${version}-setup.${ext}"
  },
  "portable": {
    "artifactName": "OmniERP-${version}-portable.${ext}"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.business"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Office"
  }
}
