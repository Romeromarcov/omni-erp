# Perfil de build standalone de Cobranza (ADR-008 / Plan D — D4).
# Vite carga este archivo con: vite build --mode cobranza  (npm run build:cobranza)
VITE_APP_PROFILE=cobranza

# CxC Lubrikca siempre visible en este perfil; opcionalmente fija la empresa:
# VITE_CXC_LUBRIKCA_EMPRESAS=<uuid-empresa-lubrikca>
